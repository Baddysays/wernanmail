# Public mail hostname. Change both before exposing this server.
MAIL_HOSTNAME=localhost
MAIL_EHLO=localhost
PUBLIC_URL=https://localhost

ADMIN_USER=admin
# ADMIN_PASSWORD, SESSION_SECRET, and MAIL_MASTER_PASSWORD are generated on
# first install and kept in a Docker volume, not in this file.

# Public ports. Change HTTP/HTTPS only when another reverse proxy owns 80/443.
HTTP_PORT=80
HTTPS_PORT=443
SMTP_PORT=25
SUBMISSION_PORT=587
IMAP_PORT=143

# HTTP sessions require HTTPS by default.
COOKIE_SECURE=true

# RELAY_HOST=smtp-relay.example.com:587
