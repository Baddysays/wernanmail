# Optional process config — copy to .env (never commit .env)

# HTTP listen address
ADDR=:8080

# Comma-separated Vite origins allowed with credentials
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set true behind HTTPS
COOKIE_SECURE=false

# Session cookie name (httpOnly)
SESSION_COOKIE=wernan_sid

# Session lifetime in hours (in-memory store for MVP)
SESSION_TTL_HOURS=24

# --- Test mailbox (optional local overrides; do not commit real secrets) ---
# MAIL_USERNAME=player@example.com
# MAIL_PASSWORD=
# IMAP_HOST=
# IMAP_PORT=993
# SMTP_HOST=
# SMTP_PORT=587
