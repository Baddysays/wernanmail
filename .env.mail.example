MAIL_HOSTNAME=mail.example.com
MAIL_EHLO=mail.example.com
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
# Or bcrypt hash instead of plaintext:
# ADMIN_PASSWORD_HASH=$2a$10$...
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_CORS_ORIGINS=https://mail.example.com,http://127.0.0.1:5174

# Superuser / "login as user" (Mailcow-style). Toggle also in admin settings.
# MAIL_MASTER_PASSWORD=long-random-master-password
# WEBMAIL_URL=https://mail.example.com

# TLS for SMTP submission + IMAP STARTTLS (recommended in production)
# MAIL_TLS_CERT=/etc/ssl/certs/mail.fullchain.pem
# MAIL_TLS_KEY=/etc/ssl/private/mail.key

MAIL_SMTP_PORT=2525
MAIL_SUBMIT_PORT=2587
MAIL_IMAP_PORT=2143
MAIL_ADMIN_HTTP_PORT=3090
# RELAY_HOST=smtp-relay.example.com:587
# CLAMAV_ADDR=clamav:3310
